{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "api/mcp.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/\\.well-known/mcp", "dest": "/api/mcp" },
    { "src": "/mcp", "dest": "/api/mcp" },
    { "src": "/healthz", "dest": "/api/mcp" },
    { "src": "/", "dest": "/api/mcp" }
  ]
}
