# Pendraic MCP server — environment template
# Copy to .env.local and fill in real values.

# Supabase project used by Pendraic. The MCP server calls it directly.
PENDRAIC_SUPABASE_URL=https://your-project.supabase.co
PENDRAIC_SUPABASE_ANON_KEY=

# HS256 secret matching Pendraic's Supabase JWT secret. Required to verify
# Bearer tokens. Find it in the Supabase dashboard: Project Settings → API →
# JWT Settings → "JWT Secret".
SUPABASE_JWT_SECRET=

# Optional: expected `iss` claim on incoming tokens. Defaults to Supabase's
# project issuer. Set when running behind a custom domain.
# SUPABASE_JWT_ISSUER=

# Stdio-only: the bearer token the MCP server uses on every request. For
# local installs this is stored in the Claude Desktop config under env.
# Ignored when MCP_TRANSPORT=http (HTTP reads the Authorization header).
PENDRAIC_MCP_TOKEN=

# Optional: override default transport and port.
# MCP_TRANSPORT=stdio
# PORT=3000
